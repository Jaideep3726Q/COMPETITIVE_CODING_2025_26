class Solution {
  public:
    int powMod(int x, int n, int M) {
      long long int ans=1;
      long long int xx = (long long int)x;
      while(n>0){
        if(n&1)
          ans = (ans*xx)%M;
        
        xx = (xx*xx)%M;
        n>>=1;
          
      }
      
      return (int)(ans%M);
    }
};
