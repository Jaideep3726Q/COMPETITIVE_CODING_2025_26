#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    bool isCycle(int V, vector<vector<int>>& edges) {
        vector<vector<int>> adj(V);
        
        for (auto& edge : edges) {
            int u = edge[0];
            int v = edge[1];
            adj[u].push_back(v);
            adj[v].push_back(u);
        }
        
        vector<bool> visited(V, false);
        
        for (int i = 0; i < V; i++) {
            if (!visited[i]) {
                if (bfs(i, visited, adj)) return true;
            }
        }
        
        return false;
    }
    
private:
    bool bfs(int start, vector<bool>& visited, vector<vector<int>>& adj) {
        queue<pair<int,int>> q;
        q.push({start, -1});
        visited[start] = true;
        
        while (!q.empty()) {
            auto [node, parent] = q.front();
            q.pop();
            
            for (int neighbor : adj[node]) {
                if (!visited[neighbor]) {
                    visited[neighbor] = true;
                    q.push({neighbor, node});
                } else if (neighbor != parent) {
                    return true;
                }
            }
        }
        
        return false;
    }
};
